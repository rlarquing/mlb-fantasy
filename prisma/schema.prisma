// MLB Fantasy - Esquema de base de datos completo estilo "Mister"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Usuario del juego
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  avatar        String?
  image         String?
  googleId      String?  @unique
  totalPoints   Int      @default(0)
  balance       Int      @default(100000000)
  role          String   @default("user")
  status        String   @default("pending")
  paymentStatus String   @default("unpaid")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  lastPaymentDate  DateTime?
  paymentDueDate   DateTime?
  isPaid           Boolean  @default(false)
  
  predictions      Prediction[]
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  notifications    Notification[]
  reportsMade      Report[]   @relation("UserReports")
  reportsReceived  Report[]   @relation("UserReported")
  cheatAlerts      CheatAlert[] @relation("UserCheatAlerts")
  signings         Signing[]
  lineupEntries    LineupEntry[]
  transfersFrom    Transfer[] @relation("TransfersFrom")
  transfersTo      Transfer[] @relation("TransfersTo")
  leagueMemberships LeagueMember[]
  createdLeagues   League[]   @relation("CreatedLeagues")
  payments         Payment[]
}

// Equipos de MLB
model MLBTeam {
  id          String   @id @default(cuid())
  name        String
  shortName   String
  city        String
  logo        String?
  division    String
  wins        Int      @default(0)
  losses      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  homeGames   Game[]   @relation("HomeTeam")
  awayGames   Game[]   @relation("AwayTeam")
  players     Player[]
}

// Partidos
model Game {
  id              String   @id @default(cuid())
  homeTeamId      String
  awayTeamId      String
  gameDate        DateTime
  stadium         String?
  homeScore       Int?
  awayScore       Int?
  status          String   @default("scheduled")
  winnerId        String?
  week            Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  homeTeam        MLBTeam @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        MLBTeam @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions     Prediction[]
  playerStats     PlayerGameStat[]
}

// Jugadores MLB
model Player {
  id            String   @id @default(cuid())
  name          String
  teamId        String?
  position      String
  number        Int?
  photo         String?
  battingHand   String?
  throwingHand  String?
  
  avg           Float?
  hr            Int      @default(0)
  rbi           Int      @default(0)
  runs          Int      @default(0)
  sb            Int      @default(0)
  obp           Float?
  slg           Float?
  ops           Float?
  
  era           Float?
  wins          Int      @default(0)
  losses        Int      @default(0)
  saves         Int      @default(0)
  strikeouts    Int      @default(0)
  whip          Float?
  inningsPitched Float?
  
  price         Int      @default(5000000)
  marketValue   Int      @default(5000000)
  previousPrice Int      @default(5000000)
  isStar        Boolean  @default(false)
  isFree        Boolean  @default(true)
  totalFantasyPoints Int @default(0)
  avgPoints     Float?
  ownership     Float    @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  team          MLBTeam? @relation(fields: [teamId], references: [id])
  signings      Signing[]
  lineupEntries LineupEntry[]
  transfers     Transfer[]  @relation("PlayerTransfers")
  gameStats     PlayerGameStat[]
}

// Estadísticas de jugador por partido
model PlayerGameStat {
  id          String   @id @default(cuid())
  playerId    String
  gameId      String
  week        Int
  
  atBats      Int      @default(0)
  hits        Int      @default(0)
  runs        Int      @default(0)
  rbi         Int      @default(0)
  hr          Int      @default(0)
  sb          Int      @default(0)
  bb          Int      @default(0)
  so          Int      @default(0)
  doubles     Int      @default(0)
  triples     Int      @default(0)
  
  ip          Float?
  er          Int      @default(0)
  k           Int      @default(0)
  bb_allowed  Int      @default(0)
  wins        Int      @default(0)
  saves       Int      @default(0)
  losses      Int      @default(0)
  
  points      Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  player      Player   @relation(fields: [playerId], references: [id])
  game        Game     @relation(fields: [gameId], references: [id])
}

// Fichajes de jugadores por usuarios
model Signing {
  id          String   @id @default(cuid())
  userId      String
  playerId    String
  price       Int
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  player      Player   @relation(fields: [playerId], references: [id])

  @@unique([userId, playerId])
}

// Liga
model League {
  id              String   @id @default(cuid())
  name            String
  description     String?
  createdBy       String
  budget          Int      @default(100000000)
  maxPlayers      Int      @default(25)
  lineupSize      Int      @default(9)
  marketOpen      Boolean  @default(true)
  monthlyFee      Int      @default(500)
  season          String
  isActive        Boolean  @default(true)
  marketOpenDate  DateTime?
  marketCloseDate DateTime?
  seasonStart     DateTime?
  seasonEnd       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  creator         User     @relation("CreatedLeagues", fields: [createdBy], references: [id])
  members         LeagueMember[]
  pointRules      PointRule[]
  lineups         Lineup[]
  transfers       Transfer[]
}

// Miembro de Liga
model LeagueMember {
  id          String   @id @default(cuid())
  leagueId    String
  userId      String
  isActive    Boolean  @default(true)
  totalPoints Int      @default(0)
  joinedAt    DateTime @default(now())
  
  league      League   @relation(fields: [leagueId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

// Lineup semanal
model Lineup {
  id          String   @id @default(cuid())
  leagueId    String
  userId      String
  week        Int
  season      String
  isSet       Boolean  @default(false)
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  league      League   @relation(fields: [leagueId], references: [id])
  entries     LineupEntry[]

  @@unique([leagueId, userId, week, season])
}

// Entrada de lineup
model LineupEntry {
  id          String   @id @default(cuid())
  lineupId    String?
  userId      String
  playerId    String
  position    String
  isStarter   Boolean  @default(true)
  isCaptain   Boolean  @default(false)
  points      Int      @default(0)
  week        Int      @default(1)
  createdAt   DateTime @default(now())
  
  lineup      Lineup?  @relation(fields: [lineupId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  player      Player   @relation(fields: [playerId], references: [id])
}

// Reglas de puntuación
model PointRule {
  id          String   @id @default(cuid())
  leagueId    String
  category    String   @default("batting")
  action      String
  points      Int
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  league      League   @relation(fields: [leagueId], references: [id])
}

// Transferencias
model Transfer {
  id          String   @id @default(cuid())
  leagueId    String
  playerId    String
  fromUserId  String?
  toUserId    String?
  price       Int
  type        String   @default("buy")
  status      String   @default("completed")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  
  league      League   @relation(fields: [leagueId], references: [id])
  player      Player   @relation("PlayerTransfers", fields: [playerId], references: [id])
  fromUser    User?    @relation("TransfersFrom", fields: [fromUserId], references: [id])
  toUser      User?    @relation("TransfersTo", fields: [toUserId], references: [id])
}

// Mercado de transferencias (jugadores en venta)
model TransferMarket {
  id          String   @id @default(cuid())
  sellerId    String
  playerId    String
  price       Int
  status      String   @default("pending")
  buyerId     String?
  createdAt   DateTime @default(now())
  soldAt      DateTime?
}

// Pagos de usuarios
model Payment {
  id              String   @id @default(cuid())
  userId          String
  amount          Int
  method          String   @default("transfermovil")
  reference       String?
  phoneNumber     String?
  status          String   @default("pending")
  month           String
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id])
}

// Predicciones de los usuarios
model Prediction {
  id           String   @id @default(cuid())
  userId       String
  gameId       String
  predictedWinnerId String
  predictedHomeScore Int?
  predictedAwayScore Int?
  points       Int      @default(0)
  isCorrect    Boolean?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id])
  game         Game     @relation(fields: [gameId], references: [id])
}

// Chat - Salas de chat
model ChatRoom {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("public")
  gameId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  messages    Message[]
}

// Chat - Mensajes
model Message {
  id          String   @id @default(cuid())
  content     String
  senderId    String
  receiverId  String?
  roomId      String?
  createdAt   DateTime @default(now())
  
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  room        ChatRoom? @relation(fields: [roomId], references: [id])
}

// Configuración del juego
model GameConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// Temporada
model Season {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("upcoming")
  currentWeek Int      @default(1)
  marketOpen  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Anuncios del administrador
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("info")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notificaciones para usuarios
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  data        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}

// Reportes de usuarios
model Report {
  id              String   @id @default(cuid())
  reporterId      String
  reportedUserId  String
  reason          String
  description     String?
  status          String   @default("pending")
  reviewedBy      String?
  reviewedAt      DateTime?
  resolution      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  reporter        User     @relation("UserReports", fields: [reporterId], references: [id])
  reportedUser    User     @relation("UserReported", fields: [reportedUserId], references: [id])
}

// Alertas de trampas
model CheatAlert {
  id              String   @id @default(cuid())
  userId          String
  type            String
  severity        String   @default("medium")
  description     String
  data            String?
  resolved        Boolean  @default(false)
  resolvedBy      String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  
  user            User     @relation("UserCheatAlerts", fields: [userId], references: [id])
}
